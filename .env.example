# ─────────────────────────────────────────────────────────────────────────────
# Drishti Backend — Environment Variables Template
# Copy this file to .env and fill in your values.
# On Railway: add these via Dashboard → Project → Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=production
PORT=8080

# MongoDB Atlas
DB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_very_strong_jwt_secret_here
JWT_ACCESS_EXPIRATION_MINUTES=50
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_EXPIRATION_MINUTES=50
JWT_VERIFY_EXPIRATION_MINUTES=50

# Twilio (SMS / OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2Factor (OTP fallback)
TWO_FACTOR_API_KEY=your_2factor_api_key

# Encryption
IV=0123456789abcdef0123456789abcdef
CRYPT_PASSWORD=your_crypt_password
ENCRYPTION_KEY=your_32_char_encryption_key_here

# AWS S3
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-s3-bucket-name
BUCKET_NAME=your-bucket-name
BUCKET_URL=your-bucket-url

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# ⚠️ On Railway, paste the private key with literal \n (not real newlines)
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n
FIREBASE_SERVER_KEY=your_firebase_server_key
